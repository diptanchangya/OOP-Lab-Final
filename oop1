import java.util.Scanner;

// Abstraction
interface SecurityDevice {
    void activate();
    void showInfo();
}

// Encapsulation
abstract class Device implements SecurityDevice {
    private String name;
    private boolean status;
    private final String ownerName = "Dip Tanchangya";
    private final String ownerId = "242-35-206";

    public Device(String name) { this.name = name; }

    public void showInfo() {
        System.out.println("Device: " + name);
        System.out.println("Owner: " + ownerName + " | ID: " + ownerId);
    }

    protected void setStatus(boolean s) { status = s; }
}

// Inheritance
class SmartCamera extends Device {
    public SmartCamera(String n) { super(n); }
    public void activate() { setStatus(true); System.out.println("Camera Recording..."); }
}

class SmartAlarm extends Device {
    public SmartAlarm(String n) { super(n); }
    public void activate() { setStatus(true); System.out.println("Alarm Ringing!!!"); }
}

// Polymorphism + Menu
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.println("Select System:\n1. Front Camera\n2. Gate Alarm");
        int choice = sc.nextInt();

        SecurityDevice d;
        if (choice == 1) d = new SmartCamera("Front Camera");
        else if (choice == 2) d = new SmartAlarm("Gate Alarm");
        else { System.out.println("Invalid!"); return; }

        d.showInfo();
        d.activate();
    }
}
